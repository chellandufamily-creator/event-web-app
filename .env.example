# Firebase client SDK (same values as Firebase console → Project settings → Your apps → Web app)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — enables Google Analytics (same as measurementId in Firebase console)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: local emulators (development only)
# Firestore: host:port (default port 8080 if omitted)
# NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# Auth: full origin URL shown when you run `firebase emulators:start`
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_URL=http://127.0.0.1:9099

# Server-only: Firebase Admin (Project settings → Service accounts → Generate new private key). Paste JSON as one line.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Server + middleware: signing key for session JWT (min 32 chars). Example: openssl rand -hex 32
SESSION_SECRET=

# Google Drive API (server-only; never NEXT_PUBLIC_*). OAuth refresh token for a Drive-enabled project.
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
# Top-level folder in "My Drive"; subfolders uploads/ and album/ are created automatically on server start.
ROOT_FOLDER_NAME=

# --- Hosting (e.g. Vercel) ---
# Copy every variable above into the host's "Environment Variables" UI (Production + Preview as needed).
# Firebase Console → Authentication → Settings → Authorized domains → add your deployment host (e.g. *.vercel.app and your custom domain).
# Cookies use Secure in production (HTTPS). For custom HTTPS previews, set FORCE_SECURE_COOKIES=1.
# Large uploads: app/api/upload uses maxDuration 300s — Vercel Hobby limits serverless time (~10s); use Pro or smaller batches for big files.

# Event camera roll (e.g. My Drive / Chellandu-Event-2026 / 31.03.2026 / 101NZ6_2) — open folder in Drive, copy ID from URL .../folders/FOLDER_ID
GOOGLE_DRIVE_CAMERA_FOLDER_ID=
# Optional: comma-separated folder IDs for parent folders you also want locked (no uploads/subfolders/deletes there).
# GOOGLE_DRIVE_IMMUTABLE_FOLDER_IDS=idForChellanduEvent2026,idFor31032026
